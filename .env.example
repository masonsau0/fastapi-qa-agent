# Copy to .env and fill in. NEVER commit .env.

# Required: Anthropic API key for the agent. The eval run costs $1-3 total.
# Set a spending cap on the Anthropic console BEFORE generating a key.
ANTHROPIC_API_KEY=

# Optional but recommended: GitHub Personal Access Token (read-only, public_repo
# scope only). Used by the benchmark miner and the find_pr_for_commit tool.
# Without it you'll hit the unauthenticated 60 req/hr rate limit fast.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Server config (defaults are fine for local use)
USE_MOCK=false
